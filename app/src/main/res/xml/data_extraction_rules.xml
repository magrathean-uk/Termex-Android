<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="termex_secrets.xml"/>
        <exclude domain="sharedpref" path="termex_secrets_v2.xml"/>
        <include domain="database" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="termex_secrets.xml"/>
        <exclude domain="sharedpref" path="termex_secrets_v2.xml"/>
        <include domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>
